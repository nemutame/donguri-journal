{
  "name": "donguri-journal",
  "version": "0.1.4",
  "description": "Local-first, time-aware journaling memory server over MCP",
  "license": "MIT",
  "author": "Nemutame",
  "type": "module",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "journal",
    "memory",
    "local-first",
    "sqlite",
    "embeddings",
    "ai",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nemutame/donguri-journal.git"
  },
  "homepage": "https://github.com/nemutame/donguri-journal#readme",
  "bugs": {
    "url": "https://github.com/nemutame/donguri-journal/issues"
  },
  "bin": {
    "donguri-journal": "dist/index.js"
  },
  "files": ["dist", "README.ja.md"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^12.11.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "sharp": "^0.32.6"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "sharp": "^0.32.6",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
